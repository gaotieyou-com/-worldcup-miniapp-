<view class="custom-tab-bar">
  <view class="tab-bar-inner">
    <view class="tab-item {{selected===index?'active':''}}" wx:for="{{list}}" wx:key="index" data-index="{{index}}" bindtap="switchTab">
      <image class="tab-icon" src="{{selected===index?item.selectedIconPath:item.iconPath}}" mode="aspectFit"></image>
      <text class="tab-text" style="color:{{selected===index?selectedColor:color}}">{{item.text}}</text>
    </view>
  </view>
</view>