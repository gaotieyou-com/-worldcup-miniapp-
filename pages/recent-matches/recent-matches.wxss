.recent-page{box-sizing:border-box;min-height:100vh;padding-bottom:calc(48rpx + env(safe-area-inset-bottom))}.content{padding:20rpx 20rpx 0}.date-group{margin-bottom:20rpx}.date-group:last-child{margin-bottom:0}.match-list{display:-webkit-flex;display:flex;flex-direction:column;gap:20rpx}.match-item{overflow:hidden}.empty-state{align-items:center;background:var(--white);border:1rpx solid #eee;border-radius:var(--radius-lg);color:var(--text-muted);display:-webkit-flex;display:flex;flex-direction:column;font-size:26rpx;gap:16rpx;margin:0 20rpx;padding:80rpx 0}.empty-icon{height:64rpx;opacity:.6;width:64rpx}.ad-container{border-radius:16rpx;margin:20rpx 0;min-height:240rpx;overflow:hidden}