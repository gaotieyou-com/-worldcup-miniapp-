.search-page{box-sizing:border-box;min-height:100vh;padding-bottom:20rpx}.search-bar-wrap{padding:20rpx}.search-box{align-items:center;background:hsla(0,0%,100%,.92);border-radius:40rpx;box-shadow:var(--shadow-sm,0 2rpx 8rpx rgba(0,0,0,.04));display:-webkit-flex;display:flex;gap:16rpx;height:64rpx;padding:0 24rpx}.search-icon-svg{flex-shrink:0;height:32rpx;width:32rpx}.search-input{color:#1a2332;flex:1;font-size:28rpx;height:64rpx;line-height:64rpx}.search-placeholder{color:#8899a6;font-size:26rpx}.search-clear{align-items:center;display:-webkit-flex;display:flex;flex-shrink:0;height:48rpx;justify-content:center;width:48rpx}.clear-icon{height:28rpx;width:28rpx}.section-label{color:hsla(0,0%,100%,.9);font-size:24rpx;font-weight:600;padding:0 20rpx 20rpx}.group-tabs{flex-wrap:wrap;gap:12rpx;padding:0 20rpx 20rpx}.group-tab,.group-tabs{display:-webkit-flex;display:flex}.group-tab{align-items:center;background:#fff;border:2rpx solid #e8edf1;border-radius:12rpx;box-sizing:border-box;color:#4a5e6b;font-size:26rpx;font-weight:600;height:52rpx;justify-content:center;width:calc((100% - 60rpx)/6)}.group-tab.active{background:#e5c462;border-color:transparent;color:#0d3b2e}.team-list{padding:0 20rpx}.team-item{align-items:center;background:#fff;border:1rpx solid #eee;border-radius:var(--radius-md);box-shadow:var(--shadow-sm);display:-webkit-flex;display:flex;gap:24rpx;margin-bottom:20rpx;padding:28rpx 24rpx}.team-item .flag-image.tiny{height:72rpx;width:72rpx}.team-item:active{background:#f8faf8}.team-info{display:-webkit-flex;display:flex;flex:1;flex-direction:column;gap:6rpx;min-width:0}.team-name-cn{color:#1a2332;font-size:32rpx;font-weight:600}.team-name-en{color:#8899a6;font-size:24rpx}.team-group-tag{background:#e8f5e9;border-radius:8rpx;color:#0d3b2e;font-size:24rpx;font-weight:600;padding:8rpx 20rpx}.team-arrow,.team-group-tag{flex-shrink:0}.team-arrow{height:28rpx;opacity:.4;width:28rpx}.result-hint{color:hsla(0,0%,100%,.85);font-size:24rpx;padding:0 20rpx 20rpx}.result-hint.empty{color:hsla(0,0%,100%,.65);font-size:28rpx;padding:80rpx 20rpx;text-align:center}.empty-state{align-items:center;background:var(--white);border:1rpx solid #eee;border-radius:var(--radius-lg);color:var(--text-muted);display:-webkit-flex;display:flex;flex-direction:column;font-size:26rpx;gap:16rpx;margin:0 20rpx;padding:80rpx 0}.empty-icon{height:64rpx;opacity:.6;width:64rpx}.ad-container{border-radius:16rpx;margin:0 20rpx 20rpx;min-height:240rpx;overflow:hidden}