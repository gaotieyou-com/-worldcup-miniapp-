.team-detail-page{box-sizing:border-box;min-height:100vh;padding-bottom:calc(140rpx + env(safe-area-inset-bottom))}.team-header{background:var(--white);border:1rpx solid #eee;border-radius:var(--radius-lg);box-shadow:var(--shadow-sm);gap:28rpx;margin:20rpx;padding:24rpx 30rpx}.team-flag-large,.team-header{align-items:center;display:-webkit-flex;display:flex}.team-flag-large{background:#f5f8f5;border-radius:50%;flex-shrink:0;height:120rpx;justify-content:center;overflow:hidden;width:120rpx}.team-meta{flex:1;flex-direction:column;gap:8rpx;min-width:0}.team-meta,.team-title-row{display:-webkit-flex;display:flex}.team-title-row{align-items:baseline;gap:12rpx}.team-name-cn{color:#1a2332;font-size:var(--font-xl);font-weight:700}.team-sub-row{align-items:center;color:#4a5e6b;display:-webkit-flex;display:flex;font-size:24rpx;gap:12rpx}.team-divider{color:#d5e0d8}.team-group{color:#0d3b2e;font-weight:600}.team-detail-page match-card{display:block;margin:0 20rpx 20rpx}.empty-state{align-items:center;background:var(--white);border:1rpx solid #eee;border-radius:var(--radius-lg);color:var(--text-muted);display:-webkit-flex;display:flex;flex-direction:column;font-size:26rpx;gap:16rpx;margin:0 20rpx;padding:80rpx 0}.empty-icon{height:64rpx;opacity:.6;width:64rpx}.ad-container{border-radius:16rpx;margin:0 20rpx 20rpx;overflow:hidden}