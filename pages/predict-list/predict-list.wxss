.predict-page{box-sizing:border-box;min-height:100vh;overflow-x:hidden;width:100%}.predict-list-page{padding:0 20rpx}.page-state{align-items:center;display:-webkit-flex;display:flex;flex-direction:column;gap:24rpx;padding:240rpx 0}.state-text{color:#8a8c8b;font-size:28rpx}.state-btn{background:hsla(38,43%,60%,.15);border-radius:32rpx;color:#c5a56f;font-size:26rpx;margin-top:16rpx;padding:16rpx 48rpx}.empty-wrap{align-items:center;display:-webkit-flex;display:flex;flex-direction:column;gap:16rpx;padding:200rpx 0}.empty-title{color:#fff;font-size:32rpx;font-weight:500}.empty-sub{color:#8a8c8b;font-size:26rpx}.empty-cta{background:linear-gradient(135deg,#c5a56f,#b8924a);border-radius:40rpx;color:#0d3b2e;font-size:28rpx;font-weight:600;margin-top:36rpx;padding:20rpx 60rpx}.empty-cta:active{opacity:.85}.pill-tab-bar{margin-bottom:20rpx;margin-top:24rpx;white-space:nowrap}.pill-tab-bar pill-tab{display:inline-block;margin-right:16rpx}.pill-tab-bar pill-tab:last-child{margin-right:0}.list-wrap{flex-direction:column;gap:20rpx;margin-top:20rpx}.list-card,.list-wrap{display:-webkit-flex;display:flex}.list-card{align-items:stretch;background:rgba(13,59,46,.5);border:1rpx solid hsla(38,43%,60%,.18);border-radius:16rpx;gap:8rpx;padding:22rpx 14rpx;transition:background .15s}.list-card:active{background:rgba(13,59,46,.65)}.card-col-left{align-items:center;display:-webkit-flex;display:flex;flex:0 0 auto;flex-direction:column;gap:4rpx;justify-content:center;min-width:140rpx;text-align:center}.card-date{font-feature-settings:"tnum";color:hsla(0,0%,100%,.65);font-size:22rpx;font-variant-numeric:tabular-nums;font-weight:500;line-height:1.3}.card-time{font-feature-settings:"tnum";color:#fff;font-size:40rpx;font-variant-numeric:tabular-nums;font-weight:700;line-height:1.1;margin-top:2rpx}.card-stage{background:rgba(70,124,93,.35);border-radius:8rpx;color:#d6bd8a;font-size:22rpx;font-weight:500;line-height:1.3;margin-top:10rpx;padding:6rpx 14rpx}.card-col-mid{--team-name-line-height:36rpx;justify-content:space-between;position:relative}.card-col-mid,.team-block{align-items:center;display:-webkit-flex;display:flex;flex:1;min-width:0}.team-block{justify-content:center}.team-tap{align-items:center;display:-webkit-inline-flex;display:inline-flex;flex-direction:column}.team-vs{color:hsla(0,0%,100%,.55);font-size:40rpx;font-weight:600;left:50%;line-height:1;position:absolute;top:calc(50% - 20rpx);transform:translate(-50%,-50%)}.list-card .team-flag.vertical .name{color:hsla(0,0%,100%,.92)}.card-col-right{align-items:center;display:-webkit-flex;display:flex;flex:0 0 auto;flex-direction:column;gap:6rpx;justify-content:center;min-width:140rpx;text-align:center}.mine-label{color:hsla(0,0%,100%,.6);font-size:22rpx;line-height:1.3}.mine-score{font-feature-settings:"tnum";color:#c5a56f;font-size:44rpx;font-variant-numeric:tabular-nums;font-weight:700;letter-spacing:2rpx;line-height:1.1}.card-edit-btn{background:transparent;border:1rpx solid #c5a56f;border-radius:28rpx;color:#c5a56f;font-size:24rpx;font-weight:500;line-height:1.3;margin-top:6rpx;padding:10rpx 30rpx}.card-edit-btn:active{background:hsla(38,43%,60%,.18)}.card-locked-badge{background:hsla(0,0%,100%,.08);border-radius:28rpx;color:hsla(0,0%,100%,.5);font-size:22rpx;line-height:1.3;margin-top:6rpx;padding:8rpx 22rpx}.empty-tab-wrap{padding:120rpx 0}.list-bottom-spacer{height:calc(48rpx + env(safe-area-inset-bottom))}.ad-container{border-radius:16rpx;margin-top:20rpx;overflow:hidden}.modal-mask{align-items:center;background:rgba(0,0,0,.6);bottom:0;display:-webkit-flex;display:flex;justify-content:center;left:0;position:fixed;right:0;top:0;z-index:1000}.modal-card{background:#1b5240;border-radius:24rpx;box-shadow:0 16rpx 40rpx rgba(0,0,0,.4);max-width:600rpx;padding:36rpx 32rpx;width:80%}