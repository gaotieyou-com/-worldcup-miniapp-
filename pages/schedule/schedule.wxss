.schedule-page{box-sizing:border-box;min-height:100vh;padding-bottom:calc(200rpx + env(safe-area-inset-bottom));position:relative}.date-picker{padding:20rpx 0}.date-scroll,.filter-scroll{white-space:nowrap}.filter-scroll{display:-webkit-flex;display:flex;gap:0;overflow-x:auto;padding:0 20rpx}.chip-day{font-size:28rpx;font-weight:600}.chip-week{font-size:20rpx;font-weight:500}.chip-week-weekend{color:rgba(229,196,98,.7)}.chip-week-active{color:rgba(13,59,46,.6)}.chip-week-active-weekend{color:#a8893a}.chip-today-dot{background:#4caf50;border-radius:50%;height:8rpx;margin-top:2rpx;width:8rpx}.chip-today-dot.is-active{background:#467c5d}.match-list{padding:0}.match-list-card{--schedule-avatar-size:86rpx;--team-name-line-height:36rpx;gap:20rpx;margin:0 20rpx;padding:0}.empty-state,.match-list-card{display:-webkit-flex;display:flex;flex-direction:column}.empty-state{align-items:center;background:var(--white);border:1rpx solid #eee;border-radius:var(--radius-lg);color:var(--text-muted);font-size:26rpx;gap:16rpx;margin:20rpx 20rpx 0;padding:80rpx 0}.empty-icon{height:64rpx;opacity:.6;width:64rpx}.fab-bracket{bottom:220rpx;flex-direction:column;gap:10rpx;position:fixed;right:40rpx;z-index:35}.fab-bracket,.fab-circle{align-items:center;display:-webkit-flex;display:flex}.fab-circle{animation:fabPulse 2.5s ease-in-out infinite;background:#e5c462;border:4rpx solid hsla(0,0%,100%,.35);border-radius:50%;box-shadow:0 12rpx 40rpx rgba(0,0,0,.22),0 4rpx 12rpx rgba(0,0,0,.12);height:112rpx;justify-content:center;width:112rpx}.fab-bracket:active .fab-circle{transform:scale(.9)}@-webkit-keyframes fabPulse{0%,100%{box-shadow:0 12rpx 40rpx rgba(0,0,0,.22),0 0 0 0 rgba(229,196,98,.45)}50%{box-shadow:0 12rpx 40rpx rgba(0,0,0,.22),0 0 0 28rpx rgba(229,196,98,0)}}@keyframes fabPulse{0%,100%{box-shadow:0 12rpx 40rpx rgba(0,0,0,.22),0 0 0 0 rgba(229,196,98,.45)}50%{box-shadow:0 12rpx 40rpx rgba(0,0,0,.22),0 0 0 28rpx rgba(229,196,98,0)}}.fab-icon{height:52rpx;width:52rpx}.fab-label{background:rgba(13,59,46,.78);border-radius:999rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.18);color:#fff;font-size:26rpx;font-weight:600;letter-spacing:2rpx;line-height:1;padding:8rpx 18rpx}.match-list-card .match-card.mode-compact .tbd-team{gap:8rpx}.match-list-card .match-card.mode-compact .tbd-flag{border:2rpx solid transparent}.match-list-card .match-card.mode-compact .tbd-name{color:#3a4a5c;font-size:28rpx;font-weight:600;line-height:var(--team-name-line-height,36rpx);white-space:nowrap;word-break:normal}.ad-container{border-radius:16rpx;margin:0 20rpx 20rpx;min-height:240rpx;overflow:hidden}