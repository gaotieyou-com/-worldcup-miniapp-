r:#d4a017;font-size:30rpx}.dist-row.rank-2 .rank-num{color:#a0a8b0;font-size:28rpx}.dist-row.rank-3 .rank-num{color:#c97d4d;font-size:28rpx}.dist-score-col{align-items:center;display:-webkit-flex;display:flex;flex-shrink:0;gap:10rpx;width:200rpx}.dist-score{color:#1a2332;font-size:26rpx;font-variant-numeric:tabular-nums;font-weight:500}.dist-row.rank-1 .dist-score{color:#0a1628;font-weight:700}.dist-bar-wrap{background:rgba(10,22,40,.06);border-radius:8rpx;flex:1;height:16rpx;min-width:60rpx;overflow:hidden}.dist-bar{background:linear-gradient(90deg,#4a9b6f,#1e7a52);border-radius:8rpx;height:100%;transition:width .3s ease-out}.dist-row.rank-1 .dist-bar{background:linear-gradient(90deg,#f7de8b,#e5c462)}.dist-row.rank-2 .dist-bar{background:linear-gradient(90deg,#d8dce0,#b0b6bd)}.dist-row.rank-3 .dist-bar{background:linear-gradient(90deg,#e2a07c,#c97d4d)}.dist-right{align-items:flex-end;display:-webkit-flex;display:flex;flex-direction:column;flex-shrink:0;gap:2rpx;min-width:96rpx}.dist-pct{color:#0f4230;font-size:24rpx;font-weight:700}.dist-row.rank-1 .dist-pct{color:#8c7030}.dist-count{color:#8899a6;font-size:20rpx}.dist-row.is-mine{background:linear-gradient(135deg,rgba(255,232,160,.55),hsla(46,87%,76%,.28));position:relative}.dist-row.is-mine .dist-score{color:#0a1628;font-weight:700}.mine-badge{align-items:center;background:linear-gradient(135deg,#f7de8b,#e5c462);border-radius:16rpx;box-shadow:0 1rpx 3rpx rgba(0,0,0,.08);color:#6b4f0e;display:-webkit-inline-flex;display:inline-flex;flex-shrink:0;font-size:18rpx;font-weight:700;letter-spacing:0.4rpx;line-height:1.4;padding:2rpx 10rpx}.ad-container{border-radius:16rpx;margin:0 0 16rpx;min-height:240rpx;overflow:hidden}