.pick-page{min-height:100vh}.page-body{padding-bottom:0;padding-left:20rpx;padding-right:20rpx}.page-bottom-spacer{height:calc(48rpx + env(safe-area-inset-bottom));width:100%}.pick-hero{padding:20rpx 8rpx 24rpx;text-align:center}.pick-hero-title{color:#f7de8b;font-size:40rpx;font-weight:700;letter-spacing:4rpx;margin-bottom:16rpx;text-shadow:0 0 12rpx rgba(229,196,98,.45)}.pick-hero-divider{background:linear-gradient(90deg,transparent,rgba(229,196,98,.7),transparent);height:2rpx;margin:0 auto 16rpx;width:200rpx}.pick-hero-sub{color:hsla(0,0%,100%,.7);font-size:24rpx;letter-spacing:0.5rpx;line-height:1.6}.pick-search-bar{align-items:center;background:hsla(0,0%,100%,.95);border-radius:36rpx;box-shadow:0 4rpx 12rpx rgba(10,22,40,.18);display:-webkit-flex;display:flex;gap:12rpx;height:72rpx;margin-bottom:20rpx;padding:0 20rpx;position:-webkit-sticky;position:sticky;top:0;z-index:10}.pick-search-icon{flex-shrink:0;height:28rpx;opacity:.75;width:28rpx}.pick-search-input{color:#1a2332;flex:1;font-size:26rpx;height:72rpx;line-height:72rpx}.pick-search-placeholder{color:rgba(10,22,40,.4)}.pick-search-clear{align-items:center;display:-webkit-flex;display:flex;flex-shrink:0;height:36rpx;justify-content:center;width:36rpx}.pick-search-clear image{height:24rpx;opacity:.6;width:24rpx}.pick-empty{color:hsla(0,0%,100%,.7);font-size:26rpx;padding:80rpx 0;text-align:center}.pick-groups{display:-webkit-flex;display:flex;flex-direction:column;gap:16rpx}.pick-group{background:hsla(0,0%,100%,.92);border-radius:var(--radius-md,16rpx);overflow:hidden}.pick-group-header{background:linear-gradient(90deg,hsla(46,87%,76%,.3),rgba(229,196,98,.1));border-bottom:1rpx solid rgba(10,22,40,.05);color:#0f4230;font-size:24rpx;font-weight:700;letter-spacing:1rpx;padding:14rpx 20rpx}.pick-group-list{flex-direction:column}.pick-group-list,.pick-team-row{display:-webkit-flex;display:flex}.pick-team-row{align-items:center;border-bottom:1rpx solid rgba(10,22,40,.05);gap:16rpx;padding:18rpx 20rpx;transition:background .15s ease-out}.pick-team-row:last-child{border-bottom:none}.pick-team-row:active{background:rgba(10,22,40,.04)}.pick-team-flag{box-shadow:0 1rpx 4rpx rgba(0,0,0,.2)}.pick-team-flag,.pick-team-flag-placeholder{border-radius:4rpx;flex-shrink:0;height:40rpx;width:56rpx}.pick-team-flag-placeholder{background:rgba(10,22,40,.06)}.pick-team-info{display:-webkit-flex;display:flex;flex:1;flex-direction:column;gap:4rpx;min-width:0}.pick-team-name{color:#1a2332;font-size:28rpx;font-weight:600;line-height:1.2}.pick-team-code{color:#8899a6;font-size:20rpx;letter-spacing:1rpx}.pick-team-row.is-selected{background:linear-gradient(135deg,rgba(255,232,160,.55),hsla(46,87%,76%,.28))}.pick-team-row.is-selected .pick-team-name{color:#0f4230;font-weight:700}.pick-team-row.is-selected .pick-team-code{color:#2d6e54}.pick-team-check{align-items:center;background:linear-gradient(135deg,#f7de8b,#e5c462);border-radius:50%;box-shadow:0 2rpx 6rpx rgba(229,196,98,.45);display:-webkit-flex;display:flex;flex-shrink:0;height:44rpx;justify-content:center;width:44rpx}.pick-team-check image{height:26rpx;width:26rpx}.pick-team-row.is-eliminated{background:rgba(10,22,40,.04);cursor:not-allowed;opacity:.45}.pick-team-row.is-eliminated .pick-team-flag{filter:grayscale(100%)}.pick-team-row.is-eliminated .pick-team-name{color:#6b7280;font-weight:500;text-decoration:line-through;text-decoration-color:hsla(220,9%,46%,.4)}.pick-team-row.is-eliminated .pick-team-code{color:#9ca3af}.pick-team-elim-tag{background:hsla(220,9%,46%,.1);border-radius:16rpx;color:#6b7280;flex-shrink:0;font-size:22rpx;padding:6rpx 14rpx;white-space:nowrap}.pick-team-row.is-eliminated-prev-pick{background:linear-gradient(135deg,rgba(229,196,98,.08),rgba(229,196,98,.02));border:1rpx solid rgba(229,196,98,.55);box-shadow:0 2rpx 6rpx rgba(229,196,98,.15);opacity:1}.pick-team-row.is-eliminated-prev-pick .pick-team-flag{filter:grayscale(60%)}.pick-team-row.is-eliminated-prev-pick .pick-team-name{color:#6b7280;text-decoration:none}.pick-prev-pick-hint{background:hsla(0,0%,100%,.92);border-radius:var(--radius-md,16rpx);color:#6b7280;font-size:24rpx;letter-spacing:0.5rpx;line-height:1.5;margin-top:16rpx;padding:18rpx 24rpx;text-align:center}