.heatmap-page{min-height:100vh}.page-body{padding:0 20rpx}.page-bottom-spacer{height:calc(24rpx + env(safe-area-inset-bottom));width:100%}.empty-wrap,.loading-wrap{align-items:center;display:-webkit-flex;display:flex;justify-content:center;padding:80rpx 0}.empty-text,.loading-text{color:hsla(0,0%,100%,.6);font-size:26rpx}.heatmap-full-list{background:hsla(0,0%,100%,.92);border-radius:var(--radius-md);overflow:hidden}.heatmap-row{align-items:center;border-bottom:1rpx solid rgba(10,22,40,.05);display:-webkit-flex;display:flex;gap:12rpx;padding:16rpx 20rpx}.heatmap-row:last-child{border-bottom:none}.heatmap-rank{align-items:center;display:-webkit-flex;display:flex;flex-shrink:0;justify-content:center;width:44rpx}.rank-num{color:#6b7785;font-size:26rpx;font-weight:700}.heatmap-row.rank-1 .rank-num{color:#d4a017;font-size:30rpx}.heatmap-row.rank-2 .rank-num{color:#a0a8b0;font-size:28rpx}.heatmap-row.rank-3 .rank-num{color:#c97d4d;font-size:28rpx}.heatmap-team{align-items:center;display:-webkit-flex;display:flex;flex-shrink:0;gap:10rpx;width:200rpx}.heatmap-flag{box-shadow:0 1rpx 4rpx rgba(0,0,0,.2)}.heatmap-flag,.heatmap-flag-placeholder{border-radius:4rpx;flex-shrink:0;height:28rpx;width:40rpx}.heatmap-flag-placeholder{background:rgba(10,22,40,.06)}.heatmap-name{color:#1a2332;font-size:26rpx;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.heatmap-row.rank-1 .heatmap-name{color:#0a1628;font-weight:700}.heatmap-bar-wrap{background:rgba(10,22,40,.06);border-radius:8rpx;flex:1;height:16rpx;min-width:60rpx;overflow:hidden}.heatmap-bar{background:linear-gradient(90deg,#4a9b6f,#1e7a52);border-radius:8rpx;height:100%;transition:width .3s ease-out}.heatmap-row.rank-1 .heatmap-bar{background:linear-gradient(90deg,#f7de8b,#e5c462)}.heatmap-row.rank-2 .heatmap-bar{background:linear-gradient(90deg,#d8dce0,#b0b6bd)}.heatmap-row.rank-3 .heatmap-bar{background:linear-gradient(90deg,#e2a07c,#c97d4d)}.heatmap-right{align-items:flex-end;display:-webkit-flex;display:flex;flex-direction:column;flex-shrink:0;gap:2rpx;min-width:96rpx}.heatmap-pct{color:#0f4230;font-size:24rpx;font-weight:700}.heatmap-row.rank-1 .heatmap-pct{color:#8c7030}.heatmap-count{color:#8899a6;font-size:20rpx}.heatmap-row.is-mine{background:linear-gradient(135deg,rgba(255,232,160,.55),hsla(46,87%,76%,.28));position:relative}.heatmap-row.is-mine .heatmap-name{color:#0a1628;font-weight:700}.mine-badge{align-items:center;background:linear-gradient(135deg,#f7de8b,#e5c462);border-radius:16rpx;box-shadow:0 1rpx 3rpx rgba(0,0,0,.08);color:#6b4f0e;display:-webkit-inline-flex;display:inline-flex;flex-shrink:0;font-size:18rpx;font-weight:700;letter-spacing:0.4rpx;line-height:1.4;padding:2rpx 10rpx}.ad-container{border-radius:16rpx;overflow:hidden}