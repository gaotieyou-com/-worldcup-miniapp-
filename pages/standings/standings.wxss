.standings-page{background:linear-gradient(180deg,#0d3b2e,#1e7a52 30%,#4a9b6f 50%,#94c4a8 75%,#cce2d4);box-sizing:border-box;min-height:100vh;padding-bottom:calc(140rpx + env(safe-area-inset-bottom))}.group-tabs{padding:20rpx}.tab-list{flex-wrap:wrap;gap:12rpx}.tab-item,.tab-list{display:-webkit-flex;display:flex}.tab-item{align-items:center;background:#fff;border:2rpx solid #e8edf1;border-radius:12rpx;box-sizing:border-box;color:#4a5e6b;font-size:26rpx;font-weight:600;height:52rpx;justify-content:center;width:calc((100% - 60rpx)/6)}.tab-item.active{background:#e5c462;border-color:transparent;color:#0d3b2e}.tab-letter{font-weight:700}.tab-item.live{border-color:#ff6b6b}.tab-live-mark{color:#f33;font-size:18rpx;margin-left:2rpx}.group-title-bar{justify-content:space-between;padding:20rpx 20rpx 8rpx}.group-title-bar,.group-title-left{align-items:center;display:-webkit-flex;display:flex}.group-title-left{gap:12rpx}.group-title-icon{height:40rpx;width:40rpx}.group-title-text{color:var(--text-primary);font-size:34rpx;font-weight:700}.group-title-sub{color:var(--text-muted);font-size:22rpx}.standings-table{border:none;overflow:hidden;padding:0}.table-header,.table-row{align-items:center;display:-webkit-flex;display:flex;padding:24rpx}.table-header{background:#0d3b2e;color:#fff;font-size:26rpx;font-weight:600}.table-header .col-merge,.table-header .col-num,.table-header .col-points,.table-header .col-rank,.table-header .col-team{color:#fff;font-size:24rpx;font-weight:600}.table-row{border-bottom:2rpx solid #f0f4f0;color:#3a5c4e;font-size:30rpx;font-weight:500;transition:background .15s}.table-row:last-child{border-bottom:none}.table-row:active{background:#f8faf9}.table-row.qualified{background:rgba(45,139,78,.08)}.table-row.qualified:active{background:rgba(45,139,78,.14)}.col-rank{color:#1a2332;flex-shrink:0;font-size:30rpx;font-weight:600;justify-content:center;margin-right:8rpx;width:70rpx}.col-rank,.col-team{align-items:center;display:-webkit-flex;display:flex}.col-team{flex:1;min-width:160rpx}.table-header .col-team{padding-left:12rpx}.standings-table .team-flag .name{color:#1a2332;font-size:30rpx;font-weight:600}.standings-table .flag-image.tiny{height:64rpx;width:64rpx}.col-num{width:50rpx}.col-merge,.col-num{color:#1a2332;font-size:30rpx;font-weight:600;text-align:center}.col-merge{font-variant-numeric:tabular-nums;letter-spacing:0}.col-wdl{width:110rpx}.col-gfa{width:160rpx}.col-points{color:#1a2332;font-size:30rpx;font-weight:600;text-align:center;width:70rpx}.standings-page .card{margin-left:20rpx;margin-right:20rpx}.rules-card{overflow:hidden;padding:0}.rules-card-header{padding:24rpx 24rpx 16rpx}.rules-card-header,.rules-card-left{align-items:center;display:-webkit-flex;display:flex}.rules-card-left{gap:16rpx}.rules-card-icon{flex-shrink:0;height:36rpx;width:36rpx}.rules-card-title{color:#0d3b2e;font-size:28rpx;font-weight:600}.rules-card-content{padding:0 24rpx 24rpx}.rule-section{display:-webkit-flex;display:flex;flex-direction:column;gap:12rpx}.rule-section-title{color:var(--text-primary);font-size:26rpx;font-weight:600}.rule-divider{background:#f0f4f0;height:2rpx;margin:20rpx 0}.rule-text{color:var(--text-secondary);display:block;font-size:26rpx;line-height:1.6}.sort-hint{align-items:center;background:#f5f7f6;border-radius:8rpx;color:#4a5e6b;display:-webkit-flex;display:flex;font-size:22rpx;gap:8rpx;justify-content:center;margin:16rpx 24rpx 8rpx;padding:12rpx 20rpx}.sort-icon{flex-shrink:0;height:20rpx;width:20rpx}.ad-container{border-radius:16rpx;margin:0 20rpx 20rpx;overflow:hidden}