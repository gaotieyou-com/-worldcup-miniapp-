.profile-page{box-sizing:border-box;min-height:100vh;overflow-x:hidden;padding-bottom:calc(140rpx + env(safe-area-inset-bottom));width:100%}.profile-header{align-items:center;display:-webkit-flex;display:flex;gap:24rpx;padding:24rpx 20rpx 30rpx}.profile-avatar{background:hsla(0,0%,100%,.1);border:4rpx solid hsla(0,0%,100%,.3);border-radius:50%;flex-shrink:0;height:120rpx;width:120rpx}.profile-info{display:-webkit-flex;display:flex;flex:1;flex-direction:column;gap:10rpx;min-width:0}.profile-name{color:#fff;font-size:36rpx;font-weight:700;letter-spacing:1rpx;line-height:1.2}.profile-status{align-items:center;display:-webkit-flex;display:flex;gap:8rpx;line-height:1.2}.profile-status-emoji{font-size:22rpx;line-height:1}.profile-status-text{color:hsla(0,0%,100%,.85);font-size:24rpx}.profile-switch{align-items:center;background:hsla(0,0%,100%,.15);border-radius:50%;display:-webkit-flex;display:flex;flex-shrink:0;height:64rpx;justify-content:center;transition:all .2s;width:64rpx}.profile-switch:active{background:hsla(0,0%,100%,.3);transform:scale(.92)}.switch-icon{height:32rpx;width:32rpx}.stats-row{gap:16rpx;margin:0 20rpx 24rpx}.stat-card,.stats-row{display:-webkit-flex;display:flex}.stat-card{align-items:center;background:hsla(0,0%,100%,.08);border:1rpx solid hsla(0,0%,100%,.14);border-radius:var(--radius-md);box-sizing:border-box;flex:1;flex-direction:column;gap:8rpx;justify-content:center;min-width:0;padding:24rpx 12rpx 20rpx}.stat-value-line{align-items:baseline;display:-webkit-flex;display:flex;gap:4rpx;line-height:1.1}.stat-value{font-feature-settings:"tnum";color:#f7de8b;font-size:44rpx;font-weight:700;letter-spacing:1rpx}.stat-unit{color:hsla(46,87%,76%,.85);font-size:22rpx;font-weight:500}.stat-label{color:hsla(0,0%,100%,.72);font-size:22rpx;letter-spacing:0.5rpx}.stat-card-champion{transition:all .15s ease}.stat-card-champion:active{background:hsla(0,0%,100%,.12);transform:scale(.97)}.stat-card-champion.has-selected,.stat-card-predict.has-selected{background:rg