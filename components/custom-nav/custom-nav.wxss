.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #0D3B2E;
}

.custom-nav.transparent {
  background: transparent;
}

.nav-status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  height: 20px; /* 固定高度20px */
}

.nav-left {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.nav-left-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.nav-favorite {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-fav-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-placeholder {
  width: 100%;
}