.score-input-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.score-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.team-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.score-controls {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #0D3B2E;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.score-btn.disabled {
  background: #cccccc;
  color: #999999;
}

.score-btn:active:not(.disabled) {
  transform: scale(0.95);
  background: #1a5c3a;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #0D3B2E;
  min-width: 48rpx;
  text-align: center;
}

.score-vs {
  font-size: 24rpx;
  color: #999999;
  margin: 0 16rpx;
}